{
  "name": "KanjiJigen",
  "description": "app for etymology for kanji",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "128": "images/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "tabs"
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["kanji-data.json"],
      "matches": ["<all_urls>"]
    }
  ]
}